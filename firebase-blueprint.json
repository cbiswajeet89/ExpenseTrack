{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user account",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "manager", "member"] },
        "createdAt": { "type": "string" },
        "avatar": { "type": "string" },
        "isSimulated": { "type": "boolean" }
      },
      "required": ["id", "email", "name", "role", "createdAt"]
    },
    "Group": {
      "title": "Group",
      "description": "Shared expense room/group",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "currency": { "type": "string" },
        "members": { "type": "array" },
        "memberRoles": { "type": "object" },
        "createdAt": { "type": "string" },
        "totalExpense": { "type": "number" }
      },
      "required": ["id", "name", "description", "currency", "members", "memberRoles", "createdAt", "totalExpense"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Individual transaction split",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "groupId": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "date": { "type": "string" },
        "paidBy": { "type": "string" },
        "splitMethod": { "type": "string", "enum": ["equal", "exact", "shares"] },
        "splits": { "type": "array" },
        "items": { "type": "array" },
        "category": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "groupId", "description", "amount", "currency", "date", "paidBy", "splitMethod", "splits", "category", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of system users"
    },
    "groups/{groupId}": {
      "schema": "Group",
      "description": "Collection of shared groups"
    },
    "expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Collection of itemized expense transactions"
    }
  }
}
